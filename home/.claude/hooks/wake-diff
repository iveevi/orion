#!/bin/sh
# wake-diff — report files changed since the last baseline.
# Fires on UserPromptSubmit; stdout is injected into the model's context as
# ambient awareness. Name-status only (cheap, always-on); /catch-up pulls the
# full hunks on demand for the files it decides to act on.
. "$(dirname "$0")/wake-lib.sh"

wake_resolve || exit 0
base=$(cat "$wake_base" 2>/dev/null) || exit 0
[ -n "$base" ] || exit 0

now=$(wake_snapshot_tree)
[ -n "$now" ] || exit 0

changed=$(git -C "$wake_root" diff-tree --name-status -r "$base" "$now" 2>/dev/null)
[ -n "$changed" ] || exit 0

printf 'Files you changed since my last turn (run /catch-up to continue them):\n%s\n' "$changed"
exit 0
